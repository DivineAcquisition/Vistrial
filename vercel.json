{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/send-messages",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/follow-ups",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/quote-followups",
      "schedule": "0 10 * * *"
    }
  ]
}
