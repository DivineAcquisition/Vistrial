# ===========================================
# VISTRIAL LOCAL DEVELOPMENT
# ===========================================
# Copy this file to .env.local and fill in the values
# Never commit .env.local to version control!

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Vistrial
NODE_ENV=development

# ===========================================
# SUPABASE (Required)
# ===========================================
# For local development with Supabase CLI:
# Run `supabase start` and use the outputted values
# Or use your cloud project credentials

# Cloud project (recommended for development):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Local Supabase (alternative):
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ===========================================
# STRIPE (Required for billing features)
# ===========================================
# Use test mode keys for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_test_starter_monthly
STRIPE_PRICE_STARTER_ANNUAL=price_test_starter_annual
STRIPE_PRICE_GROWTH_MONTHLY=price_test_growth_monthly
STRIPE_PRICE_GROWTH_ANNUAL=price_test_growth_annual
STRIPE_PRICE_SCALE_MONTHLY=price_test_scale_monthly
STRIPE_PRICE_SCALE_ANNUAL=price_test_scale_annual

# ===========================================
# TELNYX (Required for SMS/Voice/Number Lookup)
# ===========================================
# Same API key powers SMS sending, voice, and phone number validation
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=your_public_key
TELNYX_MESSAGING_PROFILE_ID=your_messaging_profile_id
TELNYX_WEBHOOK_SECRET=your_webhook_secret

# ===========================================
# TWILIO (Alternative to Telnyx)
# ===========================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# ELEVENLABS (Required for voice drops)
# ===========================================
ELEVENLABS_API_KEY=your_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ===========================================
# EMAIL (Optional for local dev)
# ===========================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Vistrial <noreply@localhost>

# ===========================================
# CRON SECRET (Required)
# ===========================================
# Generate with: openssl rand -hex 32
CRON_SECRET=dev_cron_secret_change_in_production
