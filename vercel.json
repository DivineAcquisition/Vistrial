{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/webhooks/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/messaging/voice/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/agent/cron/queue-scans", "schedule": "0 7 * * *" },
    { "path": "/api/agent/cron/process-scan", "schedule": "*/2 7-8 * * *" },
    { "path": "/api/agent/cron/morning-brief", "schedule": "0 8 * * *" },
    { "path": "/api/cron/health-scan", "schedule": "0 6 * * *" },
    { "path": "/api/cron/weekly-brief", "schedule": "0 7 * * 1" },
    { "path": "/api/cron/morning-priorities", "schedule": "0 8 * * *" },
    { "path": "/api/cron/auto-execute", "schedule": "30 8 * * *" },
    { "path": "/api/cron/deadline-check", "schedule": "0 9 * * *" },
    { "path": "/api/cron/renewal-check", "schedule": "30 9 * * *" },
    { "path": "/api/cron/milestone-check", "schedule": "0 10 * * *" },
    {
      "path": "/api/cron/execute-workflows",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-workflows",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/send-messages",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/check-balances",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-Requested-With, Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/embed.js",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/book/:slug",
      "destination": "/book/:slug"
    },
    {
      "source": "/embed/:slug",
      "destination": "/embed/:slug"
    }
  ]
}
