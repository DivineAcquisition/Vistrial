# ===========================================
# VISTRIAL ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env.local for local development
# For production, set these in Vercel Dashboard > Settings > Environment Variables

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Vistrial
NODE_ENV=development

# ===========================================
# SUPABASE
# ===========================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# Use your custom domain if configured, e.g. https://api.vistrial.io
# Otherwise use the default: https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://api.vistrial.io
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# ===========================================
# STRIPE (Payments & Subscriptions)
# ===========================================
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans
# Create products in Stripe Dashboard and add their price IDs here
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly
STRIPE_PRICE_GROWTH_ANNUAL=price_growth_annual
STRIPE_PRICE_SCALE_MONTHLY=price_scale_monthly
STRIPE_PRICE_SCALE_ANNUAL=price_scale_annual

# Enhanced Plan Price IDs (Lite/Pro/Agency)
STRIPE_PRICE_LITE_MONTHLY_ID=price_lite_monthly
STRIPE_PRICE_LITE_YEARLY_ID=price_lite_yearly
STRIPE_PRICE_PRO_MONTHLY_ID=price_pro_monthly
STRIPE_PRICE_PRO_YEARLY_ID=price_pro_yearly
STRIPE_PRICE_AGENCY_MONTHLY_ID=price_agency_monthly
STRIPE_PRICE_AGENCY_YEARLY_ID=price_agency_yearly

# Usage overage price IDs (metered billing)
STRIPE_PRICE_SMS_OVERAGE_ID=price_sms_overage
STRIPE_PRICE_EMAIL_OVERAGE_ID=price_email_overage
STRIPE_PRICE_VOICE_OVERAGE_ID=price_voice_overage

# ===========================================
# TELNYX (SMS, Voice & Number Lookup)
# ===========================================
# Get these from: https://portal.telnyx.com/#/app/api-keys
# The API key is used for SMS sending, voice calls, AND number lookup/validation
TELNYX_API_KEY=KEY...your_api_key
TELNYX_PUBLIC_KEY=your_public_key
TELNYX_MESSAGING_PROFILE_ID=your_messaging_profile_id
TELNYX_WEBHOOK_SECRET=your_webhook_secret

# ===========================================
# TWILIO (Alternative SMS Provider)
# ===========================================
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# ELEVENLABS (Voice Synthesis)
# ===========================================
# Get these from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ===========================================
# EMAIL (Resend)
# ===========================================
# Get these from: https://resend.com/api-keys
RESEND_API_KEY=re_...your_api_key
RESEND_FROM_EMAIL=Vistrial <noreply@mail.vistrial.io>
RESEND_REPLY_TO=support@vistrial.io

# ===========================================
# CRON & SECURITY
# ===========================================
# Generate a random secret for cron job authentication
# Use: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

# ===========================================
# OPTIONAL: GOOGLE OAUTH
# ===========================================
# Configure in Supabase Dashboard > Authentication > Providers > Google
# https://supabase.com/docs/guides/auth/social-login/auth-google
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# OPTIONAL: ANALYTICS
# ===========================================
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ===========================================
# OPTIONAL: ERROR TRACKING
# ===========================================
# SENTRY_DSN=https://your_sentry_dsn
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
